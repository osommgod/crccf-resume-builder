{
  "name": "crccf-resume-builder",
  "version": "1.0.0",
  "description": "CRCCF Resume Builder - Full Stack Application with Separate Deployments",
  "private": true,
  "scripts": {
    "start": "cd backend && npm start",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && npm run dev",
    "build": "npm run build:frontend",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "cd backend && echo 'Backend build complete'",
    "test": "cd backend && npm test",
    "lint": "cd backend && npm run lint",
    "lint:fix": "cd backend && npm run lint:fix",
    "install:all": "npm install && cd frontend && npm install && cd ../backend && npm install",
    "deploy:frontend": "cd frontend && vercel --prod",
    "deploy:backend": "echo 'Deploy backend via Render dashboard'"
  },
  "workspaces": [
    "frontend",
    "backend"
  ],
  "keywords": [
    "resume",
    "builder",
    "pdf",
    "email",
    "nodejs",
    "express",
    "mongodb",
    "crccf",
    "vercel",
    "render"
  ],
  "author": "CRCCF Resume Builder Team",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  }
}
