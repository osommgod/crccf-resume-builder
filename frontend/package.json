    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/crccf-resume-builder.git"
  },
  "bugs": {
    "url": "https://github.com/your-org/crccf-resume-builder/issues"
  },
  "homepage": "https://github.com/your-org/crccf-resume-builder#readme"
