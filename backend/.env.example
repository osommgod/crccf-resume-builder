# CRCCF Resume Builder - Backend Environment Variables
# Copy this file to .env and fill in your actual values

# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/resume-builder
# For local development:
# MONGO_URI=mongodb://localhost:27017/resume-builder

# Email Configuration (Gmail SMTP)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
# Note: Use an App Password for Gmail, not your regular password
# Enable 2-factor authentication and generate App Password here:
# https://myaccount.google.com/apppasswords

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d

# Admin Configuration
ADMIN_KEY=crccf-admin-2024
# Change this to a secure key for production

# Time Configuration (in minutes)
TIME_LIMIT_MINUTES=20
DEPLOYMENT_TIMESTAMP_AUTO_RESET=false

# CORS Configuration
CORS_ORIGIN=http://localhost:3000
# For production:
# CORS_ORIGIN=https://your-frontend-domain.vercel.app

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100

# File Upload Configuration
MAX_FILE_SIZE=10485760  # 10MB
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/jpg

# PDF Configuration
PDF_MAX_SIZE=10485760  # 10MB
PDF_QUALITY=high

# Security Configuration
BCRYPT_SALT_ROUNDS=12
SESSION_SECRET=your-session-secret-change-this

# Logging Configuration
LOG_LEVEL=info
LOG_FILE=logs/app.log

# Backup Configuration
ENABLE_BACKUP=false
BACKUP_INTERVAL_HOURS=24
BACKUP_RETENTION_DAYS=30

# Redis Configuration (optional, for caching)
# REDIS_URL=redis://localhost:6379
# REDIS_PASSWORD=your-redis-password

# Analytics (optional)
# GOOGLE_ANALYTICS_ID=GA_MEASUREMENT_ID
# SENTRY_DSN=your-sentry-dsn

# External Services
# CLOUDINARY_CLOUD_NAME=your-cloudinary-name
# CLOUDINARY_API_KEY=your-cloudinary-key
# CLOUDINARY_API_SECRET=your-cloudinary-secret

# Monitoring
# UPTIME_ROBOT_URL=https://uptimerobot.com/api

# Development Settings
DEBUG=false
ENABLE_SWAGGER=true
ENABLE_PLAYGROUND=true

# Production Settings
SSL_CERT_PATH=
SSL_KEY_PATH=
TRUST_PROXY=false

# Email Templates
EMAIL_TEMPLATE_DIR=templates/email
FROM_EMAIL=noreply@crccf.com
FROM_NAME=CRCCF Resume Builder

# Feature Flags
ENABLE_REGISTRATION=true
ENABLE_EMAIL_VERIFICATION=false
ENABLE_SOCIAL_LOGIN=false
ENABLE_MULTIPLE_LANGUAGES=false

# Cache Configuration
CACHE_TTL_SECONDS=3600
CACHE_MAX_SIZE=100

# Database Connection Options
DB_MAX_POOL_SIZE=10
DB_MIN_POOL_SIZE=2
DB_MAX_IDLE_TIME_MS=30000
DB_SERVER_SELECTION_TIMEOUT_MS=5000

# API Configuration
API_VERSION=v1
API_PREFIX=/api
ENABLE_API_DOCS=true

# Error Handling
ENABLE_ERROR_LOGGING=true
ENABLE_ERROR_EMAILS=false
ERROR_EMAIL_RECIPIENT=admin@crccf.com
